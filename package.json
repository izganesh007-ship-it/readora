{
    "name": "readora",
    "version": "1.0.0",
    "private": true,
    "description": "Readora - premium Netflix-style ebook marketplace with BTCPay Server, PostgreSQL, secure downloads and admin dashboard.",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "start": "node dist/server.js",
        "build": "tsc -p tsconfig.json && node scripts/copy-public.cjs",
        "db:migrate": "node scripts/migrate.mjs",
        "db:seed": "psql $DATABASE_URL -f sql/seed.sql",
        "admin:create": "tsx src/scripts/createAdmin.ts",
        "db:studio": "prisma studio",
        "lint": "eslint ."
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1085.0",
        "@aws-sdk/s3-request-presigner": "^3.1085.0",
        "argon2": "^0.44.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.3.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.2.0",
        "pg": "^8.22.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.2.0",
        "@types/node": "^26.1.1",
        "@types/pg": "^8.20.0",
        "prisma": "^7.8.0",
        "tsx": "^4.23.0",
        "typescript": "^7.0.2"
    }
}
