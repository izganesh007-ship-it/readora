# Readora production mode using the same automatic config.
# If all BTCPay variables exist, Readora uses real BTCPay automatically.
# If all R2/B2 variables exist, Readora uses private R2/B2 storage automatically.
NODE_ENV=production
PORT=8080
APP_URL=https://PASTE-YOUR-DEPLOYED-APP-URL-HERE
CORS_ORIGIN=https://PASTE-YOUR-DEPLOYED-APP-URL-HERE
DATABASE_URL=postgresql://PASTE-YOUR-POSTGRES-CONNECTION-STRING-HERE
COOKIE_SECRET=PASTE-RANDOM-SECRET-1-HERE
JWT_SECRET=PASTE-RANDOM-SECRET-2-HERE

BTCPAY_MODE=auto
BTCPAY_URL=https://PASTE-YOUR-BTCPAY-SERVER-DOMAIN-HERE
BTCPAY_API_KEY=PASTE-BTCPAY-API-KEY-HERE
BTCPAY_STORE_ID=PASTE-BTCPAY-STORE-ID-HERE
BTCPAY_WEBHOOK_SECRET=PASTE-BTCPAY-WEBHOOK-SECRET-HERE
BTCPAY_CURRENCY=USD

# Optional: NOWPayments instead of BTCPay
# NOWPAYMENTS_API_KEY=PASTE-NOWPAYMENTS-API-KEY-HERE
# NOWPAYMENTS_IPN_SECRET=PASTE-NOWPAYMENTS-IPN-SECRET-HERE

STORAGE_DRIVER=auto
# Option A: Cloudflare R2
R2_ENDPOINT=https://PASTE-YOUR-R2-ACCOUNT-ENDPOINT-HERE
R2_ACCESS_KEY_ID=PASTE-R2-ACCESS-KEY-ID-HERE
R2_SECRET_ACCESS_KEY=PASTE-R2-SECRET-ACCESS-KEY-HERE
R2_BUCKET=readora-private-ebooks
R2_REGION=auto

# Option B: Backblaze B2 (uncomment and comment out R2 above)
# B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# B2_KEY_ID=PASTE-B2-KEY-ID-HERE
# B2_APPLICATION_KEY=PASTE-B2-APPLICATION-KEY-HERE
# B2_BUCKET=readora-ebooks
# B2_REGION=us-east-005

CONFIG_AUTO_UPGRADE=true

SIGNED_URL_SECONDS=300
DOWNLOAD_TOKEN_HOURS=24
