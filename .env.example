NODE_ENV=production
PORT=8080
APP_URL=https://readora.example.com
DATABASE_URL=postgres://readora:change_me@localhost:5432/readora
COOKIE_SECRET=change_me_64_chars
JWT_SECRET=change_me_64_chars
CORS_ORIGIN=https://readora.example.com

# Automatic config. Start with these; later add BTCPay/R2/B2 keys and the app upgrades automatically.
BTCPAY_MODE=auto
STORAGE_DRIVER=auto
LOCAL_STORAGE_DIR=./storage
CONFIG_AUTO_UPGRADE=true

# First admin bootstrap only
ADMIN_EMAIL=admin@readora.example.com
ADMIN_INITIAL_PASSWORD=change-this-immediately

# BTCPay Server Greenfield API. Optional in demo; required for real payments.
BTCPAY_URL=https://btcpay.example.com
BTCPAY_API_KEY=token_from_btcpay
BTCPAY_STORE_ID=store_id
BTCPAY_WEBHOOK_SECRET=webhook_secret
BTCPAY_CURRENCY=USD

# NOWPayments (alternative payment provider for BTC). Optional.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Cloudflare R2 / S3-compatible private storage. Optional in demo; required for real private object storage.
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=readora-private-ebooks
R2_REGION=auto

# Backblaze B2 (S3-compatible). Alternative to R2.
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_KEY_ID=...
B2_APPLICATION_KEY=...
B2_BUCKET=readora-ebooks
B2_REGION=us-east-005

SIGNED_URL_SECONDS=300
DOWNLOAD_TOKEN_HOURS=24

# Security/rate limits
LOGIN_RATE_LIMIT_WINDOW_MIN=15
LOGIN_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MIN=15
API_RATE_LIMIT_MAX=300
