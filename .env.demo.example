# Readora automatic demo mode.
# Paste these first. Later, just add BTCPay/R2 variables and Readora auto-upgrades.
NODE_ENV=production
PORT=8080
APP_URL=https://PASTE-YOUR-DEPLOYED-APP-URL-HERE
CORS_ORIGIN=https://PASTE-YOUR-DEPLOYED-APP-URL-HERE
DATABASE_URL=postgresql://PASTE-YOUR-POSTGRES-CONNECTION-STRING-HERE
COOKIE_SECRET=PASTE-RANDOM-SECRET-1-HERE
JWT_SECRET=PASTE-RANDOM-SECRET-2-HERE

# Keep auto. If BTCPay keys are missing, checkout is demo/mock automatically.
BTCPAY_MODE=auto
# Keep auto. If R2/S3 keys are missing, storage is local automatically.
STORAGE_DRIVER=auto
LOCAL_STORAGE_DIR=./storage
CONFIG_AUTO_UPGRADE=true

SIGNED_URL_SECONDS=300
DOWNLOAD_TOKEN_HOURS=24
